INSERT INTO part_type(id, code, label, people_count, sex_rule, fixed, sort_order)
VALUES (lower(hex(randomblob(16))), 'SPIEGARE_CIO_CHE_SI_CREDE_DISCORSO', 'Spiegare quello in cui si crede - Discorso', 1, 'UOMO', 0, 6)
ON CONFLICT(code) DO UPDATE SET
    label = excluded.label,
    people_count = excluded.people_count,
    sex_rule = excluded.sex_rule,
    fixed = excluded.fixed,
    sort_order = excluded.sort_order,
    active = 1;

INSERT OR IGNORE INTO person_part_type_eligibility(id, person_id, part_type_id, can_lead)
SELECT
    lower(hex(randomblob(16))),
    e.person_id,
    (SELECT id FROM part_type WHERE code = 'SPIEGARE_CIO_CHE_SI_CREDE_DISCORSO'),
    e.can_lead
FROM person_part_type_eligibility e
JOIN part_type pt_d ON e.part_type_id = pt_d.id
WHERE pt_d.code = 'DISCORSO'
  AND e.can_lead = 1
  AND EXISTS (SELECT 1 FROM part_type WHERE code = 'SPIEGARE_CIO_CHE_SI_CREDE_DISCORSO');
