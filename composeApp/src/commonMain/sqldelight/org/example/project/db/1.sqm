-- Migration 1 -> 2
-- Seed (upsert) canonical Meeting Workbook partTypes. Idempotent:
-- INSERT ... ON CONFLICT(code) DO UPDATE ensures fresh installs get the 7
-- canonical types, and existing installs get their labels/metadata realigned
-- to the canonical state. `active = 1` on UPDATE re-activates any row that
-- may have been deactivated by a prior deactivateMissingCodes call.
-- Also copies conductor eligibility from DISCORSO to the new
-- SPIEGARE_CIO_CHE_SI_CREDE_DISCORSO for existing users.

INSERT INTO part_type(id, code, label, people_count, sex_rule, fixed, sort_order)
VALUES (lower(hex(randomblob(16))), 'LETTURA_DELLA_BIBBIA', 'Lettura Biblica', 1, 'UOMO', 1, 0)
ON CONFLICT(code) DO UPDATE SET
    label = excluded.label,
    people_count = excluded.people_count,
    sex_rule = excluded.sex_rule,
    fixed = excluded.fixed,
    sort_order = excluded.sort_order,
    active = 1;

INSERT INTO part_type(id, code, label, people_count, sex_rule, fixed, sort_order)
VALUES (lower(hex(randomblob(16))), 'INIZIARE_CONVERSAZIONE', 'Iniziare una conversazione', 2, 'STESSO_SESSO', 0, 1)
ON CONFLICT(code) DO UPDATE SET
    label = excluded.label,
    people_count = excluded.people_count,
    sex_rule = excluded.sex_rule,
    fixed = excluded.fixed,
    sort_order = excluded.sort_order,
    active = 1;

